<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#40FFFFFF" />

    <TextView
        android:id="@+id/tvSheetPlaceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Safe Place Name"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSheetDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="No description available"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStreetView"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Open Street View"
        android:textColor="@color/background_dark"
        app:backgroundTint="@color/golden"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_directions"
        app:iconGravity="textStart"
        app:iconTint="@color/background_dark" />

</LinearLayout>
